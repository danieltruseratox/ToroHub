-- 🎯 1. LÓGICA DEL AIMBOT UNIVERSAL
-- =============================================================================
local BotonAimbot = CrearBoton("🎯 Aimbot: DESACTIVADO", Color3.fromRGB(150, 40, 40))
local AimbotActivo = false

local function ObtenerJugadorMasCercano()
    local Objetivo = nil
    local DistanciaMaxima = math.huge
    local Camara = workspace.CurrentCamera
    
    for _, Jugador in pairs(Players:GetPlayers()) do
        if Jugador ~= JugadorLocal and Jugador.Character and Jugador.Character:FindFirstChild("HumanoidRootPart") and Jugador.Character:FindFirstChild("Humanoid") then
            if Jugador.Character.Humanoid.Health > 0 then
                local PosicionPantalla, EnPantalla = Camara:WorldToScreenPoint(Jugador.Character.HumanoidRootPart.Position)
                if EnPantalla then
                    local DistanciaMouse = (Vector2.new(Mouse.X, Mouse.Y) - Vector2.new(PosicionPantalla.X, PosicionPantalla.Y)).Magnitude
                    if DistanciaMouse < DistanciaMaxima then
                        DistanciaMaxima = DistanciaMouse
                        Objetivo = Jugador.Character.HumanoidRootPart
                    end
                end
            end
        end
    end
    return Objetivo
end

RunService.RenderStepped:Connect(function()
    if AimbotActivo then
        local Target = ObtenerJugadorMasCercano()
        if Target then
            workspace.CurrentCamera.CFrame = CFrame.new(workspace.CurrentCamera.CFrame.Position, Target.Position)
        end
    end
end)

BotonAimbot.MouseButton1Click:Connect(function()
    AimbotActivo = not AimbotActivo
    BotonAimbot.Text = AimbotActivo and "🎯 Aimbot: ACTIVADO" or "🎯 Aimbot: DESACTIVADO"
    BotonAimbot.BackgroundColor3 = AimbotActivo and Color3.fromRGB(40, 150, 40) or Color3.fromRGB(150, 40, 40)
end)

-- =============================================================================
-- 👁️ 2. LÓGICA DEL ESP (WALLHACK - CAJAS Y LÍNEAS)
-- =============================================================================
local BotonESP = CrearBotor or CrearBoton("👁️ ESP: DESACTIVADO", Color3.fromRGB(150, 40, 40))
local ESPActivo = false
local ContenedorESP = {}

local function CrearESP(jugador)
    if jugador == JugadorLocal then return end
    
    local Box = Drawing.new("Square")
    Box.Visible = false
    Box.Color = Color3.fromRGB(255, 0, 0)
    Box.Thickness = 1.5
    Box.Filled = false
    
    local Linea = Drawing.new("Line")
    Linea.Visible = false
    Linea.Color = Color3.fromRGB(255, 255, 255)
    Linea.Thickness = 1
    
    ContenedorESP[jugador] = {Box = Box, Linea = Linea}
    
    local Conectado
    Conectado = RunService.RenderStepped:Connect(function()
        if not ESPActivo or not jugador.Parent or not jugador.Character or not jugador.Character:FindFirstChild("HumanoidRootPart") or not jugador.Character:FindFirstChild("Humanoid") or jugador.Character.Humanoid.Health <= 0 then
            Box.Visible = false
            Linea.Visible = false
            if not jugador.Parent then Conectado:Disconnect() end
            return
        end
        
        local Camara = workspace.CurrentCamera
        local RootPart = jugador.Character.HumanoidRootPart
        local Pos, EnPantalla = Camara:WorldToScreenPoint(RootPart.Position)
        
        if EnPantalla then
            -- Dibujar Caja Alrededor del Enemigo
            Box.Size = Vector2.new(1000 / Pos.Z, 1500 / Pos.Z)
            Box.Position = Vector2.new(Pos.X - Box.Size.X / 2, Pos.Y - Box.Size.Y / 2)
            Box.Visible = true
            
            -- Dibujar Línea de Rastreo (Desde el centro inferior de tu pantalla)
            Linea.From = Vector2.new(Camara.ViewportSize.X / 2, Camara.ViewportSize.Y)
            Linea.To = Vector2.new(Pos.X, Pos.Y)
            Linea.Visible = true
        else
            Box.Visible = false
            Linea.Visible = false
        end
    end)
end

Players.PlayerAdded:Connect(CrearESP)
for _, p in pairs(Players:GetPlayers()) do CrearESP(p) end

BotonESP.MouseButton1Click:Connect(function()
    ESPActivo = not ESPActivo
    BotonESP.Text = ESPActivo and "👁️ ESP: ACTIVADO" or "👁️ ESP: DESACTIVADO"
    BotonESP.BackgroundColor3 = ESPActivo and Color3.fromRGB(40, 150, 40) or Color3.fromRGB(150, 40, 40)
end)

